 package log
 
 import (
+	"io"
+	"sync"
 	"strings"
 	"time"
 )
 
+// CRLFWriterWrapper normalizes log output for Windows-style text readers.
+type CRLFWriterWrapper struct {
+	Writer      io.Writer
+	InsertedCRs int
+
+	mu        sync.Mutex
+	lastWasCR bool
+}
+
+// CRLFWriter wraps w with CRLF normalization while preserving existing CRLF sequences.
+func CRLFWriter(w io.Writer) io.Writer {
+	return &CRLFWriterWrapper{Writer: w}
+}
+
+func (w *CRLFWriterWrapper) Write(p []byte) (int, error) {
+	if len(p) == 0 {
+		return 0, nil
+	}
+
+	w.mu.Lock()
+	defer w.mu.Unlock()
+
+	out := make([]byte, 0, len(p)*2)
+	cumulative := make([]int, len(p))
+
+	for i, b := range p {
+		switch b {
+		case 0:
+			out = append(out, '?')
+			w.lastWasCR = false
+		case '\n':
+			if !w.lastWasCR {
+				out = append(out, '\r')
+				w.InsertedCRs++
+			}
+			out = append(out, '\n')
+			w.lastWasCR = false
+		case '\r':
+			out = append(out, '\r')
+			w.lastWasCR = true
+		default:
+			out = append(out, b)
+			w.lastWasCR = false
+		}
+		cumulative[i] = len(out)
+	}
+
+	written, err := w.Writer.Write(out)
+	if err == nil && written != len(out) {
+		err = io.ErrShortWrite
+	}
+	if err != nil {
+		return consumedInputBytes(cumulative, written), err
+	}
+
+	return len(p), nil
+}
+
+func consumedInputBytes(cumulative []int, written int) int {
+	if written <= 0 {
+		return 0
+	}
+
+	consumed := 0
+	for _, total := range cumulative {
+		if total > written {
+			break
+		}
+		consumed++
+	}
+	return consumed
+}
